@baseUrl = http://127.0.0.1:5000
@labId = 000000000000000000000001

### List all labs
GET {{baseUrl}}/api/labs/all

###

### Get one lab
GET {{baseUrl}}/api/labs/{{labId}}

###

### Create a lab
POST {{baseUrl}}/api/labs
Content-Type: application/json

{
  "name": "Lab One",
  "labID": "12345",
  "contact": {
    "primary": "01700000000",
    "secondary": "01800000000",
    "publicEmail": "lab@example.com",
    "privateEmail": "private@example.com",
    "address": "123 Main Street",
    "district": "Dhaka",
    "zone": "Zone A"
  },
  "billing": {
    "perInvoiceFee": 10,
    "monthlyFee": 500,
    "commission": 5
  },
  "isActive": true
}

###

### Update lab name
PATCH {{baseUrl}}/api/labs/{{labId}}
Content-Type: application/json

{
  "name": "Lab One Updated"
}

###

### Update lab contact
PATCH {{baseUrl}}/api/labs/{{labId}}/contact
Content-Type: application/json

{
  "contact": {
    "primary": "01711111111",
    "secondary": "01811111111",
    "publicEmail": "new@example.com",
    "privateEmail": "newprivate@example.com",
    "address": "456 New Street",
    "district": "Chittagong",
    "zone": "Zone B"
  }
}

###

### Update lab billing
PATCH {{baseUrl}}/api/labs/{{labId}}/billing
Content-Type: application/json

{
  "billing": {
    "perInvoiceFee": 15,
    "monthlyFee": 700,
    "commission": 8
  }
}

###

### Activate lab
PATCH {{baseUrl}}/api/labs/{{labId}}/activate

###

### Deactivate lab
PATCH {{baseUrl}}/api/labs/{{labId}}/deactivate

###

### Delete a lab
DELETE {{baseUrl}}/api/labs/{{labId}}