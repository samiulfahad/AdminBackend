@baseUrl = http://127.0.0.1:5000
@labId = 000000000000000000000001
@staffId = 000000000000000000000002

### List all staff of a lab
GET {{baseUrl}}/api/labs/{{labId}}/staff

###

### Get one staff member
GET {{baseUrl}}/api/staff/{{staffId}}

###

### Create a staff member for a lab
POST {{baseUrl}}/api/labs/{{labId}}/staff
Content-Type: application/json

{
  "name": "John Doe",
  "username": "johndoe",
  "email": "john@example.com",
  "mobileNumber": "01700000000",
  "permissions": {
    "createInvoice": true,
    "editInvoice": true,
    "deleteInvoice": false,
    "cashmemo": true,
    "uploadReport": true,
    "downloadReport": true
  },
  "isActive": true
}

###

### Update a staff member
PATCH {{baseUrl}}/api/staff/{{staffId}}
Content-Type: application/json

{
  "name": "John Doe Updated",
  "username": "johndoe2",
  "email": "john2@example.com",
  "mobileNumber": "01711111111",
  "permissions": {
    "createInvoice": false,
    "editInvoice": false,
    "deleteInvoice": false,
    "cashmemo": false,
    "uploadReport": true,
    "downloadReport": true
  }
}

###

### Activate a staff member
PATCH {{baseUrl}}/api/staff/{{staffId}}/activate

###

### Deactivate a staff member
PATCH {{baseUrl}}/api/staff/{{staffId}}/deactivate

###

### Delete a staff member (soft delete)
DELETE {{baseUrl}}/api/staff/{{staffId}}